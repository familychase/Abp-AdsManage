{
  "ConnectionStrings": {
    "Default": "Server=localhost\\SQLEXPRESS;Database=EDY;User Id=sa;Password=123;TrustServerCertificate=True"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5128"
      }
    }
  },
  "AllowedHosts": "*",
  "Redis": {
    "ConnectionString": "192.168.1.44:6379"
  },
  "RabbitMq": {
    "SectionName": "RabbitMq",
    "RequestedHeartbeat":3600,
    "Host": "127.0.0.1",
    "Port": 5672,
    "VirtualHost": "/",
    "UserName": "admin",
    "Password": "admin123",
    "MaxBatchSize": 100,
    "PrefetchCount": 10,
    "RetryPolicy": {
      "MaxRetryCount": 3,
      "InitialRetryDelayMs": 1000,
      "BackoffMultiplier": 2.0,
      "MaxRetryDelayMs": 30000
    }
  },
  "DatabaseLogging": {
    "MinLevel": "Information"
  },
  "MetaApiRetry": {
    "InitialRetryDelaySeconds": 2,
    "BackoffMultiplier": 5,
    "MaxRetryDelaySeconds": 600,
    "MaxRetries": 6,
    "TransientErrorCodes": [ 1, 2, 4, 17, 32, 613, 80004 ]
  },
  "MetaApiRateLimit": {
    "Enabled": true,
    "ReadBucketCapacity": 15,
    "ReadRefillRatePerSecond": 10,
    "WriteBucketCapacity": 5,
    "WriteRefillRatePerSecond": 3,
    "MaxWaitSeconds": 30,
    "KeyPrefix": "ratelimit:meta"
  }
}
