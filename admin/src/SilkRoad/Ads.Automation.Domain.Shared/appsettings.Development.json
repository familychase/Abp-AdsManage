{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Ads.Automation": "Information"
    }
  },
  "ConnectionStrings": {
    "Default": "Server=localhost\\SQLEXPRESS;Database=EDY;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5128"
      }
    }
  },
  "Redis": {
    "ConnectionString": "192.168.110.224:6379",
    "InstanceName": "ads-automation"
  },
  "DatabaseLogging": {
    "MinLevel": "Information"
  },
  "RabbitMq": {
    "SectionName": "RabbitMq",
    "RequestedHeartbeat": 3600,
    "Host": "192.168.110.224",
    "Port": 5672,
    "VirtualHost": "/",
    "UserName": "admin",
    "Password": "admin123",
    "MaxBatchSize": 100,
    "PrefetchCount": 10,

    "RetryPolicy": {
      "MaxRetryCount": 3,
      "InitialRetryDelayMs": 1000,
      "BackoffMultiplier": 2.0,
      "MaxRetryDelayMs": 30000
    }
  },
  "MetaApiRetry": {
    "InitialRetryDelaySeconds": 2,
    "BackoffMultiplier": 5,
    "MaxRetryDelaySeconds": 600,
    "MaxRetries": 6,
    "TransientErrorCodes": [ 1, 2, 4, 17, 32, 613, 80004 ]
  },
  "MetaApiRateLimit": {
    "Enabled": true,
    "ReadBucketCapacity": 15,
    "ReadRefillRatePerSecond": 10,
    "WriteBucketCapacity": 5,
    "WriteRefillRatePerSecond": 3,
    "MaxWaitSeconds": 30,
    "KeyPrefix": "ratelimit:meta"
  }
}
